# Frontier — Lost in Space
# Copy this file to src/frontend/.env.local for local development.
#
# Required for ICP backend calls (any canister ID string works locally
# if you just want the frontend to render without a live ICP replica):
CANISTER_ID_BACKEND=aaaaa-aa

# Optional: ElevenLabs premium voice (falls back to browser TTS if unset)
VITE_ELEVEN_API_KEY=
VITE_ELEVEN_VOICE_ID=

# Optional: Blob storage gateway (defaults to https://blob.caffeine.ai)
STORAGE_GATEWAY_URL=https://blob.caffeine.ai

# Set to "local" when running against a local ICP replica (dfx/icp-cli)
# DFX_NETWORK=local
